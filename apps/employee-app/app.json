{
  "expo": {
    "name": "Pure Alpha Employee",
    "slug": "pure-alpha-employee",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "purealpha-employee",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f8f6f3"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.purealpha.employee",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Skanuj kod QR hotelu",
        "NSFaceIDUsageDescription": "Logowanie i potwierdzanie obecnosci w pracy"
      }
    },
    "android": {
      "package": "com.purealpha.employee",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1e40af"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-splash-screen",
      ["expo-camera", { "cameraPermission": "Zezwol Pure Alpha Employee na dostep do kamery w celu skanowania kodow QR." }],
      "expo-local-authentication"
    ]
  }
}
